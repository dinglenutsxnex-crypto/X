<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- ── Bubble ── -->
    <FrameLayout
        android:id="@+id/debugger_bubble"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_debugger_bubble"
        android:elevation="10dp">

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_debugger_white"
            android:contentDescription="Debugger" />
    </FrameLayout>

    <!-- ── Panel ── -->
    <LinearLayout
        android:id="@+id/debugger_panel"
        android:layout_width="416dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_debugger_panel"
        android:elevation="10dp"
        android:visibility="gone">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="4dp"
            android:background="@drawable/bg_debugger_header">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="OFF-BY-ONE DEBUGGER"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.08" />

            <!-- Triple-dot overflow menu -->
            <TextView
                android:id="@+id/btn_overflow"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:text="⋮"
                android:textColor="#CCCCCC"
                android:textSize="20sp"
                android:textStyle="bold"
                android:padding="10dp"
                android:background="@drawable/bg_btn_ripple"
                android:clickable="true" />

            <!-- Close -->
            <TextView
                android:id="@+id/btn_collapse"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:text="✕"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:padding="10dp"
                android:background="@drawable/bg_btn_ripple"
                android:clickable="true" />
        </LinearLayout>

        <!-- ═══════════════ PROCESS SELECT section ═══════════════ -->
        <LinearLayout
            android:id="@+id/section_process_select"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="6dp">

            <!-- Section label + refresh -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="4dp"
                android:paddingTop="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="RUNNING PROCESSES"
                    android:textColor="#BBBBBB"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.15" />

                <TextView
                    android:id="@+id/btn_refresh_processes"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:gravity="center"
                    android:text="REFRESH"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:background="@drawable/bg_btn_ripple"
                    android:clickable="true" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:background="#333333" />

            <!-- Process list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_processes"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:scrollbars="none"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:clipToPadding="false" />

            <!-- Empty hint -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingBottom="4dp"
                android:text="Launch an app inside the container first"
                android:textColor="#666666"
                android:textSize="9sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- ═══════════════ LOGGING section ═══════════════ -->
        <LinearLayout
            android:id="@+id/section_logging"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Attached process bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1AFFFFFF"
                android:paddingStart="14dp"
                android:paddingEnd="4dp">

                <TextView
                    android:id="@+id/tv_selected_process"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Attached"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:ellipsize="middle"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/btn_stop_logging"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:gravity="center"
                    android:text="DETACH"
                    android:textColor="#FF5555"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:background="@drawable/bg_btn_ripple"
                    android:clickable="true" />
            </LinearLayout>

            <!-- Filter bar — larger hit targets (36dp tall) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <TextView
                    android:id="@+id/btn_filter_all"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="ALL"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_filter_active"
                    android:layout_marginEnd="3dp"
                    android:clickable="true" />

                <TextView
                    android:id="@+id/btn_filter_error"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="ERR"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:textColor="#FF5555"
                    android:background="@drawable/bg_btn_ripple"
                    android:layout_marginEnd="3dp"
                    android:clickable="true" />

                <TextView
                    android:id="@+id/btn_filter_trace"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="TRACE"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:textColor="#FFFF55"
                    android:background="@drawable/bg_btn_ripple"
                    android:layout_marginEnd="3dp"
                    android:clickable="true" />

                <TextView
                    android:id="@+id/btn_clear_logs"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="CLR"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:textColor="#888888"
                    android:background="@drawable/bg_btn_ripple"
                    android:clickable="true" />
            </LinearLayout>

            <!-- Active filter label -->
            <TextView
                android:id="@+id/tv_filter_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="14dp"
                android:paddingBottom="2dp"
                android:text="ALL LOGS"
                android:textColor="#888888"
                android:textSize="8sp"
                android:fontFamily="monospace" />

            <!-- Log output -->
            <ScrollView
                android:id="@+id/scroll_logs"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_log_area"
                android:fillViewport="true"
                android:scrollbars="vertical">

                <TextView
                    android:id="@+id/tv_logs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:lineSpacingMultiplier="1.3"
                    android:text="Waiting for process attach..." />
            </ScrollView>
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
