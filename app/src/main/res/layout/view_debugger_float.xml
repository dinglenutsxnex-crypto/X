<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- ── Bubble ── -->
    <FrameLayout
        android:id="@+id/debugger_bubble"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:background="@drawable/bg_debugger_bubble"
        android:elevation="10dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_debugger_white"
            android:contentDescription="Debugger" />
    </FrameLayout>

    <!-- ── Panel (320dp * 1.3 = 416dp) ── -->
    <LinearLayout
        android:id="@+id/debugger_panel"
        android:layout_width="416dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_debugger_panel"
        android:elevation="10dp"
        android:visibility="gone">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="10dp"
            android:background="@drawable/bg_debugger_header">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="HAMMERSCALE DEBUGGER"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.08" />

            <TextView
                android:id="@+id/btn_collapse"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="✕"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ═══════════════ PROCESS SELECT section ═══════════════ -->
        <LinearLayout
            android:id="@+id/section_process_select"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="6dp">

            <!-- Section label + refresh -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="4dp"
                android:paddingTop="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="RUNNING PROCESSES"
                    android:textColor="#BBBBBB"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.15" />

                <TextView
                    android:id="@+id/btn_refresh_processes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="REFRESH"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:background="#333333" />

            <!-- Process list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_processes"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:scrollbars="none"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:clipToPadding="false" />

            <!-- Empty hint -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingBottom="4dp"
                android:text="Launch an app inside the container first"
                android:textColor="#666666"
                android:textSize="9sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- ═══════════════ LOGGING section ═══════════════ -->
        <LinearLayout
            android:id="@+id/section_logging"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Attached process bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1AFFFFFF"
                android:paddingStart="14dp"
                android:paddingEnd="4dp">

                <TextView
                    android:id="@+id/tv_selected_process"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Attached"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:ellipsize="middle"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/btn_stop_logging"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="DETACH"
                    android:textColor="#FF5555"
                    android:textSize="9sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Filter bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <TextView
                    android:id="@+id/btn_filter_all"
                    android:layout_width="0dp"
                    android:layout_height="26dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="ALL"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_filter_active"
                    android:layout_marginEnd="3dp" />

                <TextView
                    android:id="@+id/btn_filter_error"
                    android:layout_width="0dp"
                    android:layout_height="26dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="ERR"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:textColor="#FF5555"
                    android:background="@android:color/transparent"
                    android:layout_marginEnd="3dp" />

                <TextView
                    android:id="@+id/btn_filter_trace"
                    android:layout_width="0dp"
                    android:layout_height="26dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="TRACE"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:textColor="#FFFF55"
                    android:background="@android:color/transparent"
                    android:layout_marginEnd="3dp" />

                <TextView
                    android:id="@+id/btn_clear_logs"
                    android:layout_width="0dp"
                    android:layout_height="26dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="CLR"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:textColor="#888888"
                    android:background="@android:color/transparent" />
            </LinearLayout>

            <!-- Active filter label -->
            <TextView
                android:id="@+id/tv_filter_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="14dp"
                android:paddingBottom="2dp"
                android:text="ALL LOGS"
                android:textColor="#888888"
                android:textSize="8sp"
                android:fontFamily="monospace" />

            <!-- Log output -->
            <ScrollView
                android:id="@+id/scroll_logs"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_log_area"
                android:fillViewport="true"
                android:scrollbars="vertical">

                <TextView
                    android:id="@+id/tv_logs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:lineSpacingMultiplier="1.3"
                    android:text="Waiting for process attach..." />
            </ScrollView>
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
