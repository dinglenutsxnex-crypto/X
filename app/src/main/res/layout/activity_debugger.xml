<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D0D">

    <include layout="@layout/view_toolbar" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/ic_debugger"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DEBUGGER"
            android:textSize="22sp"
            android:textColor="#00BCD4"
            android:letterSpacing="0.2"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monitor running apps, trace function calls\nand capture live logs from the container."
            android:textSize="13sp"
            android:textColor="#888888"
            android:gravity="center"
            android:layout_marginBottom="40dp" />

        <Button
            android:id="@+id/btn_start_debugger"
            android:layout_width="220dp"
            android:layout_height="52dp"
            android:text="START DEBUGGER"
            android:textColor="#0D0D0D"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:backgroundTint="#00BCD4"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tv_overlay_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Requires screen overlay permission"
            android:textSize="11sp"
            android:textColor="#555555"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
