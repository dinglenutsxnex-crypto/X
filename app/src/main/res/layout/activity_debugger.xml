<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <include layout="@layout/view_toolbar" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_debugger_white"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DEBUGGER"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monitor running apps, trace function calls\nand capture live logs from the container."
            android:textSize="12sp"
            android:textColor="#888888"
            android:gravity="center"
            android:fontFamily="monospace"
            android:layout_marginBottom="40dp" />

        <TextView
            android:id="@+id/btn_start_debugger"
            android:layout_width="220dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="START DEBUGGER"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="14sp"
            android:background="#FFFFFF"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tv_overlay_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Requires screen overlay permission"
            android:textSize="10sp"
            android:textColor="#444444"
            android:fontFamily="monospace"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
