<resources xmlns:tools="http://schemas.android.com/tools">
    
    <style name="Theme.BlackBox" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <item name="colorSecondary">@color/primary_light</item>
        <item name="colorSecondaryVariant">@color/primary</item>
        <item name="colorOnSecondary">@color/white</item>
        
        <item name="android:statusBarColor" tools:targetApi="l">#000000</item>
        <item name="android:windowBackground">#000000</item>

        <item name="actionMenuTextColor">@color/primary_text</item>

        <item name="android:textColorPrimary">@color/primary_text</item>
        <item name="android:textColorSecondary">@color/secondary_text</item>
        <item name="android:textColorHint">@color/secondary_text</item>

        <!-- Force all Material surfaces dark so SwitchPreferenceCompat toggles
             and other surface-colored widgets stay visible on black backgrounds. -->
        <item name="colorSurface">#121212</item>
        <item name="colorOnSurface">@color/primary_text</item>
        <item name="colorSurfaceVariant">#1E1E1E</item>
        <item name="colorOnSurfaceVariant">@color/secondary_text</item>
        <item name="android:colorBackground">#000000</item>

        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
    </style>

    <style name="ToolBarColorStyle" parent="ThemeOverlay.AppCompat.ActionBar">
        <item name="actionMenuTextColor">#FFFFFF</item>
        <item name="colorControlNormal">#FFFFFF</item>
        <item name="android:background">#000000</item>
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
    </style>

    <style name="WelcomeTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@drawable/splash</item>
    </style>

    <!-- Chip button for the protocol filter bar in NetworkAnalyzerActivity -->
    <style name="FilterChip">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">26dp</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingEnd">10dp</item>
        <item name="android:textSize">9sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:layout_marginEnd">4dp</item>
        <item name="android:background">@android:color/transparent</item>
    </style>

    <!-- Smaller chip for the status / direction sub-filter row -->
    <style name="SubFilterChip">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">22dp</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:textSize">8sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:layout_marginEnd">4dp</item>
        <item name="android:background">@android:color/transparent</item>
    </style>

</resources>